{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/watch/layout,_N_T_/watch/[id]/layout,_N_T_/watch/[id]/page,_N_T_/watch/v32"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/watch/$d$id/__PAGE__",
    "/watch/$d$id",
    "/watch",
    "/_index",
    "/_head"
  ]
}